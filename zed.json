{
    "auto_signature_help": false,
    "cursor_blink": true,
    "vim": {
        "toggle_relative_line_numbers": false,
    },
    "wsl_connections": [
        {
            "distro_name": "Ubuntu",
            "user": null,
            "projects": [
                {
                    "paths": ["/home/sm0kii"],
                },
            ],
        },
    ],
    "show_wrap_guides": true,
    "agent_servers": {
        "github-copilot-cli": {
            "type": "registry",
        },
        "claude-acp": {
            "type": "registry",
        },
        "your_agent": {
            "type": "custom",
            "command": "path_to_executable",
        },
    },
    "git_panel": {
        "scrollbar": {
            "show": "auto",
        },
        "sort_by_path": true,
        "status_style": "label_color",
        "tree_view": true,
        "collapse_untracked_diff": false,
    },
    "current_line_highlight": "all",
    "text_rendering_mode": "platform_default",
    "agent_ui_font_size": 15,
    "pane_split_direction_horizontal": "down",
    "window_decorations": "client",
    "edit_predictions": {
        "mode": "subtle",
        "provider": "copilot",
        "copilot": {
            "enable_next_edit_suggestions": true,
        },
        "enabled_in_text_threads": false,
    },
    "tab_size": 4,
    "restore_on_startup": "last_session",
    "languages": {
        "Git Commit": {
            "prettier": {
                "allowed": true,
            },
        },
        "Python": {
            "colorize_brackets": true,
        },
        "JavaScript": {
            "colorize_brackets": true,
            "formatter": "prettier",
        },
        "TypeScript": {
            "colorize_brackets": true,
            "formatter": "prettier",
        },
        "C++": {
            "colorize_brackets": true,
        },
        "Python constraints": {
            "formatter": "prettier",
            "colorize_brackets": true,
            "preferred_line_length": 120,
        },
    },
    "colorize_brackets": true,
    "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_background": false,
        "edit_debounce_ms": 700,
        "scroll_debounce_ms": 50,
        "toggle_on_modifiers_press": null,
        "show_value_hints": true,
    },
    "indent_guides": {
        "enabled": true,
        "line_width": 1,
        "active_line_width": 0,
        "coloring": "indent_aware",
        "background_coloring": "disabled",
    },
    "soft_wrap": "editor_width",
    "toolbar": {
        "code_actions": true,
        "breadcrumbs": true,
    },
    "minimap": {
        "thumb": "always",
        "max_width_columns": 90,
        "display_in": "all_editors",
        "show": "always",
    },
    "autosave": "off",
    "notification_panel": {
        "button": true,
    },
    "outline_panel": {
        "button": true,
    },
    "cursor_shape": "bar",
    "use_smartcase_search": true,
    "ui_font_weight": 450,
    "ui_font_family": "JetBrainsMono Nerd Font",
    "buffer_line_height": "comfortable",
    "buffer_font_weight": 400,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "diagnostics_max_severity": "hint",
    "pane_split_direction_vertical": "right",
    "zoomed_padding": true,
    "active_pane_modifiers": {},
    "centered_layout": {
        "right_padding": null,
        "left_padding": null,
    },
    "preview_tabs": {
        "enable_preview_from_file_finder": true,
    },
    "debugger": {
        "button": true,
    },
    "search": {
        "regex": true,
        "button": true,
    },
    "diagnostics": {
        "button": true,
        "inline": {
            "enabled": true,
            "update_debounce_ms": 150,
            "padding": 2,
            "min_column": 0,
            "max_severity": "all",
        },
    },
    "status_bar": {
        "cursor_position_button": true,
        "active_language_button": true,
    },
    "tab_bar": {
        "show_pinned_tabs_in_separate_row": false,
        "show_tab_bar_buttons": true,
        "show_nav_history_buttons": true,
        "show": true,
    },
    "context_servers": {
        "mcp-server-github": {
            "enabled": true,
            "settings": {
                "github_personal_access_token": "your access token",
            },
        },
    },
    "project_panel": {
        "diagnostic_badges": true,
        "hide_hidden": false,
        "sticky_scroll": false,
        "scrollbar": {
            "show": "never",
        },
        "indent_size": 11,
        "folder_icons": true,
        "entry_spacing": "standard",
        "hide_root": false,
        "git_status": true,
        "file_icons": true,
        "dock": "left",
        "button": true,
        "hide_gitignore": false,
    },
    "disable_ai": false,
    "git": {
        "branch_picker": {
            "show_author_name": true,
        },
        "inline_blame": {
            "show_commit_summary": true,
        },
        "hunk_style": "unstaged_hollow",
    },
    "helix_mode": false,
    "vim_mode": false,
    "use_system_window_tabs": false,
    "bottom_dock_layout": "contained",
    "tabs": {
        "show_diagnostics": "all",
        "show_close_button": "hover",
        "close_position": "left",
        "file_icons": true,
        "git_status": true,
    },
    "title_bar": {
        "show_onboarding_banner": true,
        "show_project_items": true,
        "show_branch_name": true,
        "show_menus": false,
        "show_sign_in": true,
        "show_user_picture": true,
        "show_branch_icon": true,
    },
    "calls": {
        "mute_on_join": true,
    },
    "agent": {
        "inline_assistant_model": {
            "provider": "copilot_chat",
            "model": "gpt-5.1-codex-max",
            "enable_thinking": false,
        },
        "profiles": {
            "descriptive": {
                "default_model": {
                    "provider": "copilot_chat",
                    "model": "gpt-5.2",
                    "enable_thinking": false,
                },
                "name": "Descriptive",
                "tools": {},
                "enable_all_context_servers": false,
                "context_servers": {},
            },
        },
        "tool_permissions": {
            "tools": {
                "terminal": {
                    "default": "allow",
                    "always_allow": [
                        {
                            "pattern": "^cat\\b",
                        },
                        {
                            "pattern": "^grep\\b",
                        },
                        {
                            "pattern": "^sed\\b",
                        },
                    ],
                },
                "fetch": {
                    "default": "allow",
                },
                "create_directory": {
                    "default": "allow",
                },
                "mcp:mcp-server-github:search_code": {
                    "default": "allow",
                },
                "mcp:mcp-server-github:search_issues": {
                    "default": "allow",
                },
            },
        },
        "favorite_models": [
            {
                "provider": "copilot_chat",
                "model": "gpt-5.1-codex-max",
                "enable_thinking": false,
            },
            {
                "provider": "copilot_chat",
                "model": "claude-sonnet-4.5",
                "enable_thinking": false,
            },
            {
                "provider": "copilot_chat",
                "model": "claude-opus-4.6",
                "enable_thinking": false,
            },
            {
                "provider": "copilot_chat",
                "model": "gpt-5.4",
                "enable_thinking": false,
            },
            {
                "provider": "copilot_chat",
                "model": "gpt-4o",
                "enable_thinking": false,
            },
        ],
        "default_profile": "ask",
        "default_model": {
            "enable_thinking": false,
            "provider": "copilot_chat",
            "model": "gpt-4o",
        },
        "model_parameters": [],
    },
    "terminal": {
        "option_as_meta": false,
        "dock": "bottom",
        "scrollbar": {
            "show": "always",
        },
        "toolbar": {
            "breadcrumbs": false,
        },
        "default_height": 320,
        "keep_selection_on_copy": false,
        "font_weight": 400,
        "working_directory": "current_project_directory",
        "shell": {
            "with_arguments": {
                "program": "pwsh.exe",
                "args": [],
            },
        },
        "button": true,
        "blinking": "terminal_controlled",
        "cursor_shape": "underline",
        "font_family": "JetBrainsMono Nerd Font",
        "font_size": 14,
    },
    "prettier": {
        "allowed": true,
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "base_keymap": "VSCode",
    "icon_theme": {
        "mode": "system",
        "light": "Symbols Icon Theme",
        "dark": "Symbols Icon Theme",
    },
    "ui_font_size": 15.0,
    "buffer_font_size": 14.0,
    "theme": {
        "mode": "dark",
        "light": "Catppuccin Iced Latte (Blur)",
        "dark": "Catppuccin Espresso (Blur)",
